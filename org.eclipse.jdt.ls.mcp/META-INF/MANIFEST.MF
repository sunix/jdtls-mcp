Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: JDT Language Server MCP Bridge
Bundle-SymbolicName: org.eclipse.jdt.ls.mcp;singleton:=true
Bundle-Version: 1.0.0.qualifier
Bundle-Activator: org.eclipse.jdt.ls.mcp.McpServerPlugin
Bundle-RequiredExecutionEnvironment: JavaSE-17
Bundle-ActivationPolicy: lazy
Bundle-Vendor: sunix
Automatic-Module-Name: org.eclipse.jdt.ls.mcp

Require-Bundle: org.eclipse.jdt.ls.core;bundle-version="1.0.0",
 org.eclipse.core.runtime;bundle-version="3.12.0",
 org.eclipse.lsp4j;bundle-version="[0.24.0,0.25.0)"

Import-Package: org.osgi.framework;version="1.3.0",
 io.modelcontextprotocol.server,
 io.modelcontextprotocol.server.transport,
 io.modelcontextprotocol.spec,
 io.modelcontextprotocol.json,
 io.modelcontextprotocol.json.jackson2,
 dev.langchain4j.agent.tool

