<configuration>
    <!-- Write all log output to stderr so it does not interfere with MCP stdio communication -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Reduce noise from MCP SDK and reactor internals -->
    <logger name="io.modelcontextprotocol" level="WARN"/>
    <logger name="reactor" level="WARN"/>

    <!-- jdtls-mcp own classes at INFO level -->
    <logger name="io.github.sunix.jdtls.mcp" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
